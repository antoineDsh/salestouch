{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LinkedIn Message Variants",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "messages"],
  "properties": {
    "format": {
      "type": "string",
      "const": "linkedin_message_variants_v2"
    },
    "messages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
